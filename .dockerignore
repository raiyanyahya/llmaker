facade/.venv/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
facade/.pytest_cache/
facade/.ruff_cache/
facade/build/
facade/dist/

# Go test/coverage artifacts
*.test
*.out
coverage.txt
coverage.html

# Editor / OS
.DS_Store
.idea/
.vscode/
