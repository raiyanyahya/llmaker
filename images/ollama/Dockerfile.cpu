# Slim, CPU-only llmaker Ollama image.
#
# The default images/ollama/Dockerfile is ~8.5GB because the ollama/ollama base
# bundles CUDA / ROCm / MLX GPU libraries (~4GB) on top of a full Ubuntu. This
# variant takes ONLY the Ollama binary and its CPU runtime from that image and
# drops them onto a slim Python base — no GPU libraries — for a much smaller
# image well suited to CPU hosts, CI, and Docker-on-macOS.
#
#   docker build -f images/ollama/Dockerfile.cpu -t ghcr.io/raiyanyahya/llmaker-ollama:cpu .
#   llmaker up --image ghcr.io/raiyanyahya/llmaker-ollama:cpu
#
# The GPU bits are removed *inside the builder stage*, so the slimmed directory
# is what gets copied forward — the multi-GB layers never reach the final image.

# --- builder: strip the GPU libraries out of the official Ollama image ---
FROM ollama/ollama:latest AS ollama-src
RUN rm -rf \
      /usr/lib/ollama/cuda_v11 \
      /usr/lib/ollama/cuda_v12 \
      /usr/lib/ollama/cuda_v13 \
      /usr/lib/ollama/mlx_cuda_v13 \
      /usr/lib/ollama/rocm \
      /usr/lib/ollama/vulkan \
      /usr/lib/ollama/include

# --- runtime: slim Python base + CPU-only Ollama + the facade ---
FROM python:3.12-slim-bookworm

ENV LLMAKER_BACKEND=ollama \
    FACADE_PORT=8080 \
    OLLAMA_HOST=127.0.0.1:11434 \
    OLLAMA_URL=http://127.0.0.1:11434 \
    LD_LIBRARY_PATH=/usr/lib/ollama \
    PYTHONUNBUFFERED=1

RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Ollama: just the binary and the (now CPU-only) runtime libraries.
COPY --from=ollama-src /usr/bin/ollama /usr/bin/ollama
COPY --from=ollama-src /usr/lib/ollama /usr/lib/ollama

# Install the facade package (FastAPI app + static web UI). The slim Python base
# isn't PEP-668 "externally managed", so a plain pip install works.
COPY facade/ /opt/llmaker-facade/
RUN python3 -m pip install --no-cache-dir /opt/llmaker-facade

COPY images/ollama/entrypoint.sh /usr/local/bin/llmaker-entrypoint
RUN chmod +x /usr/local/bin/llmaker-entrypoint

EXPOSE 8080
VOLUME ["/root/.ollama"]

HEALTHCHECK --interval=10s --timeout=3s --start-period=40s --retries=6 \
  CMD curl -fsS "http://127.0.0.1:${FACADE_PORT}/api/health" || exit 1

ENTRYPOINT ["/usr/local/bin/llmaker-entrypoint"]
CMD []
